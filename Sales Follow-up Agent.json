      "parameters": {
        "jsCode": "const tierOneCities = [\"Mumbai\", \"Delhi\", \"Bangalore\", \"Chennai\", \"Hyderabad\", \"Kolkata\", \"Pune\", \"Ahmedabad\"];\nconst validSizes = [\"2XL\", \"3XL\", \"4XL\", \"5XL\", \"6XL\", \"7XL\"];\n\nreturn items.filter(item => {\n  const lead = item.json;\n  const sizeMatch = validSizes.includes(lead.size);\n  const locationMatch = tierOneCities.includes(lead.location);\n  const ageMatch = lead.age >= 24 && lead.age <= 35;\n  const genderMatch = lead.gender === \"Female\";\n  return sizeMatch && locationMatch && ageMatch && genderMatch;\n});"
      },
