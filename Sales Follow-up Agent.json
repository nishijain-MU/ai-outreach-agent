      "parameters": {
        "jsCode": "const httpOutputs = $input.all();\nconst leadInputs = $('Limits on leads1').all();\n\nreturn httpOutputs.map((item, index) => {\n  const emailBody = item.json.choices[0].message.content;\n  const lead = leadInputs[index].json;\n  \n  return {\n    json: {\n      name: lead.name,\n      email: lead.email,\n      size: lead.size,\n      age: lead.age,\n      location: lead.location,\n      gender: lead.gender,\n      leadId: lead.leadId,\n      emailBody: emailBody\n    }\n  };\n});"
      },
